# TapRide Environment Variables
# Copy this file to .env and fill in your values

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Fare configuration (optional — defaults shown)
# VITE_FARE_BASE=2.0
# VITE_FARE_PER_KM=0.5
# VITE_FARE_MIN=3.0
# VITE_FARE_CURRENCY=USD
# VITE_FARE_SYMBOL=$

# Nominatim User-Agent (optional — identifies your app to OSM)
# VITE_NOMINATIM_UA=TapRide/1.0
